# ClickSend SMS API
# Get these from https://dashboard.clicksend.com/account/subaccounts
CLICKSEND_USERNAME=your-clicksend-username
CLICKSEND_API_KEY=your-clicksend-api-key

# The DJ's phone number that receives booking SMS (E.164 format, e.g. +614XXXXXXXX)
DJ_PHONE_NUMBER=+614XXXXXXXX

# The "from" name shown on the SMS (max 11 alphanumeric chars). Falls back to "LV DJ" if unset.
SMS_SENDER_ID=LVDJ
